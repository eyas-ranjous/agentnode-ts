{
  "name": "agentnode-ts",
  "version": "0.1.0",
  "description": "A lightweight AI agent framework for TypeScript.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx examples/current-time/index.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eyas-ranjous/agentnode-ts.git"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "openai",
    "typescript",
    "framework",
    "tool-calling"
  ],
  "author": "Eyas Ranjous",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/eyas-ranjous/agentnode-ts/issues"
  },
  "homepage": "https://github.com/eyas-ranjous/agentnode-ts#readme",
  "dependencies": {
    "openai": "^6.46.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}